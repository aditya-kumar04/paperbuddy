# Environment file used ONLY when running the test suite (NODE_ENV=test).
# Copy this to .env.test and point it at a dedicated test database —
# never your real dev/production database, since the test suite wipes
# tables between test files.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paperbuddy_test?schema=public"
JWT_SECRET=test-jwt-secret-do-not-use-in-real-environments
JWT_REFRESH_SECRET=test-jwt-refresh-secret-do-not-use-in-real-environments
FRONTEND_URL=http://localhost:5173
