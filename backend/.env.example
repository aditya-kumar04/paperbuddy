# PostgreSQL connection string (local Postgres or a hosted provider like Neon)
DATABASE_URL="postgresql://username:password@localhost:5432/paperbuddy?schema=public"

# Port the Express server listens on (optional, defaults to 5000)
PORT=5000

# Secrets used to sign JWTs. REQUIRED — the server will refuse to start without these.
# Generate strong random values, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Comma-separated list of origins allowed to call this API (used for CORS).
# In dev this is your Vite frontend; in production add your deployed frontend URL(s).
FRONTEND_URL=http://localhost:5173
